# Logging
CHASING_BREAD_LOG_LEVEL=INFO
CHASING_BREAD_DEBUG=false

# Scraping
CHASING_BREAD_RATE_LIMIT_RPS=0.5
CHASING_BREAD_RESPECT_ROBOTS_TXT=true
CHASING_BREAD_DEFAULT_PLATFORM=xhs
CHASING_BREAD_REQUEST_TIMEOUT=30

# Search defaults
CHASING_BREAD_MAX_PAGES_PER_KEYWORD=5

# Paths (optional, auto-detected if left empty)
# CHASING_BREAD_DATA_DIR=./data

# Output
CHASING_BREAD_OUTPUT_FORMAT=json
